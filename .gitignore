# --- GhostMessage Repository Root .gitignore ---

# Ignore everything at the root by default
/*

# Allow only these specific folders and files
!/extensions/
!/ghostMessage_server/
!/.github/
!/.gitignore
!/README.md

# --- Specific Ignore Rules for Allowed Folders ---

# Backend specific (Already managed by ghostMessage_server/.gitignore but added here for safety)
**/build/
**/bin/
**/.gradle/
**/data/

# OS and IDE files
.DS_Store
Thumbs.db
.metadata/
.settings/
.project
.classpath
.factorypath

# Archive and Documentation (User requested to exclude from GitHub)
*.zip
*.tar.gz
docs/
extension_image/
plan.md
research.md
session.txt
DockerFile
